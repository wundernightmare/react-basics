{
  "name": "frontend-basics",
  "version": "0.0.1",
  "description": "Cloneable React + Vite frontend template: FSD layers, TanStack Query, Zod-validated API client, Lingui i18n, MSW test setup, Vitest + Stryker, oxlint + oxfmt.",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && pnpm manifest",
    "manifest": "node scripts/generate-manifest.mjs",
    "preview": "vite preview",
    "typecheck": "tsgo -b",
    "lint": "oxlint src tests --quiet",
    "lint:fix": "oxlint --fix src tests",
    "format": "oxfmt \"src/**/*.{ts,tsx,css}\" \"tests/**/*.ts\" \"!src/locales/**/messages.ts\"",
    "format:check": "oxfmt --check \"src/**/*.{ts,tsx,css}\" \"tests/**/*.ts\" \"!src/locales/**/messages.ts\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:node": "vitest run --project node",
    "test:jsdom": "vitest run --project jsdom",
    "test:browser": "vitest run -c vitest.browser.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run",
    "i18n:extract": "lingui extract",
    "i18n:compile": "lingui compile --typescript",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check",
    "clean": "rm -rf dist coverage reports .stryker-tmp node_modules/.tmp"
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "@lingui/core": "6.2.0",
    "@lingui/react": "6.2.0",
    "@radix-ui/react-slot": "1.2.5",
    "@tanstack/react-query": "5.101.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.17.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.78.0",
    "react-router": "7.17.0",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@lingui/babel-plugin-lingui-macro": "6.2.0",
    "@lingui/cli": "6.2.0",
    "@lingui/conf": "6.2.0",
    "@lingui/format-po": "6.2.0",
    "@lingui/swc-plugin": "6.3.0",
    "@lingui/vite-plugin": "6.2.0",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.9.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260609.1",
    "@vitejs/plugin-react-swc": "4.3.1",
    "@vitest/browser": "4.1.8",
    "@vitest/browser-playwright": "4.1.8",
    "@vitest/coverage-v8": "4.1.8",
    "jsdom": "29.1.1",
    "lefthook": "2.1.9",
    "msw": "2.14.6",
    "oxfmt": "0.54.0",
    "oxlint": "1.69.0",
    "oxlint-tsgolint": "0.23.0",
    "playwright": "1.60.0",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.8",
    "vitest-browser-react": "2.2.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild",
      "lefthook",
      "msw"
    ]
  },
  "engines": {
    "node": ">=24"
  }
}
