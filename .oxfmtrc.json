{
  "semi": true,
  "singleQuote": false,
  "tabWidth": 2,
  "trailingComma": "all",
  "printWidth": 100,
  "arrowParens": "always",
  "importOrder": [
    "^(node:.*)$",
    "<THIRD_PARTY_MODULES>",
    "^@(app|pages|widgets|features|entities|shared)/(.*)$",
    "^[./]"
  ],
  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true,
  "importOrderParserPlugins": [
    "typescript",
    "jsx",
    "decorators-legacy"
  ],
  "sortPackageJson": false,
  "ignorePatterns": [
    "dist",
    "node_modules",
    "pnpm-lock.yaml",
    "src/locales/**/messages.ts"
  ]
}
